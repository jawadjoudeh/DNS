# ── Main App ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
DB_PATH=dns_logs.db
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ── Admin Panel (runs on port 5001) ───────────────────
ADMIN_PORT=5001
ADMIN_SECRET_KEY=change-this-too
ADMIN_PANEL_TOKEN=super_secret_token

# ── Default Admin Account ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@network.local
ADMIN_PASSWORD=admin123
AUTH_DB_PATH=data/users.db

# ── Server URL (used in proxy download links) ─────────
SERVER_URL=http://localhost:5000

# ── Google OAuth (get from console.cloud.google.com) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (get from github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
